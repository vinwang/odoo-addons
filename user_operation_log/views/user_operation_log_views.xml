<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Operation Log List View -->
    <record id="user_operation_log_list_view" model="ir.ui.view">
        <field name="name">user.operation.log.list</field>
        <field name="model">user.operation.log</field>
        <field name="arch" type="xml">
            <list string="User Operation Logs">
                <field name="operation_time"/>
                <field name="user_id"/>
                <field name="operation_type"/>
                <field name="model_description"/>
                <field name="record_name"/>
                <field name="ip_address"/>
            </list>
        </field>
    </record>

    <!-- Operation Log Form View -->
    <record id="user_operation_log_form_view" model="ir.ui.view">
        <field name="name">user.operation.log.form</field>
        <field name="model">user.operation.log</field>
        <field name="arch" type="xml">
            <form string="User Operation Log">
                <header>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="operation_type" readonly="1"/>
                            <field name="model_name" readonly="1"/>
                            <field name="model_description" readonly="1"/>
                        </group>
                        <group>
                            <field name="record_id" readonly="1"/>
                            <field name="record_name" readonly="1"/>
                            <field name="operation_time" readonly="1"/>
                            <field name="ip_address" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Operation Summary" invisible="not operation_summary">
                            <field name="operation_summary" readonly="1"/>
                        </page>
                        <page string="Field Changes">
                            <field name="log_line_ids" readonly="1">
                                <list>
                                    <field name="field_description"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                </list>
                            </field>
                        </page>
                        <page string="Old Values" invisible="not old_values">
                            <field name="old_values" readonly="1"/>
                        </page>
                        <page string="New Values" invisible="not new_values">
                            <field name="new_values" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Operation Log Search View -->
    <record id="user_operation_log_search_view" model="ir.ui.view">
        <field name="name">user.operation.log.search</field>
        <field name="model">user.operation.log</field>
        <field name="arch" type="xml">
            <search string="User Operation Logs">
                <field name="user_id" string="User"/>
                <field name="operation_type" string="Operation Type"/>
                <field name="model_name" string="Model"/>
                <field name="operation_time" string="Operation Time"/>
                <field name="ip_address" string="IP Address"/>
                <group>
                    <filter string="By User" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="By Operation Type" name="group_by_operation_type" context="{'group_by': 'operation_type'}"/>
                    <filter string="By Model" name="group_by_model" context="{'group_by': 'model_name'}"/>
                    <filter string="By Date" name="group_by_date" context="{'group_by': 'operation_time'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Operation Log Action -->
    <record id="user_operation_log_action" model="ir.actions.act_window">
        <field name="name">User Operation Logs</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">user.operation.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="user_operation_log_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No operation logs found
            </p><p>
                This page displays all user operation logs in the system.
            </p>
        </field>
    </record>

    <!-- Operation Log Menu -->
    <menuitem id="user_operation_log_menu" name="User Operation Log"
              parent="base.menu_administration" sequence="16"/>
    <menuitem id="user_operation_log_submenu" name="Operation Logs"
              parent="user_operation_log_menu" action="user_operation_log_action" sequence="10"/>
</odoo>
