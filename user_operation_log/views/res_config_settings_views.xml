<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Global Configuration Settings -->
    <record id="view_user_operation_log_config_settings" model="ir.ui.view">
        <field name="name">user.operation.log.config.settings</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app_settings_block data-string="User Operation Log" string="User Operation Log" data-key="user_operation_log">
                    <block title="User Operation Log Settings">
                        <setting help="When enabled, all operations on all models will be logged by default. You can still use rules to exclude specific models/operations.">
                            <field name="user_operation_log_global_enabled"/>
                        </setting>
                    </block>
                </app_settings_block>
            </xpath>
        </field>
    </record>
</odoo>
