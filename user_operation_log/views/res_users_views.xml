<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Add log view buttons to user form -->
    <record id="view_users_form_simple_modif_user_operation_log" model="ir.ui.view">
        <field name="name">res.users.form.inherit.user.operation.log</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_user_operation_logs" type="object"
                        class="oe_stat_button" icon="fa-list-alt"
                        invisible="share">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="operation_log_count" widget="statinfo"/>
                        </span>
                    </div>
                </button>
                <button name="action_view_user_login_logs" type="object"
                        class="oe_stat_button" icon="fa-sign-in"
                        invisible="share">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="login_log_count" widget="statinfo"/>
                        </span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>
