<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Login Log List View -->
    <record id="user_login_log_list_view" model="ir.ui.view">
        <field name="name">user.login.log.list</field>
        <field name="model">user.login.log</field>
        <field name="arch" type="xml">
            <list string="User Login Logs">
                <field name="login_time"/>
                <field name="user_id"/>
                <field name="status"/>
                <field name="ip_address"/>
                <field name="user_agent"/>
                <field name="logout_time"/>
            </list>
        </field>
    </record>

    <!-- Login Log Form View -->
    <record id="user_login_log_form_view" model="ir.ui.view">
        <field name="name">user.login.log.form</field>
        <field name="model">user.login.log</field>
        <field name="arch" type="xml">
            <form string="User Login Log">
                <header>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="status" readonly="1"/>
                            <field name="login_time" readonly="1"/>
                            <field name="logout_time" readonly="1"/>
                        </group>
                        <group>
                            <field name="ip_address" readonly="1"/>
                            <field name="session_id" readonly="1"/>
                            <field name="failure_reason" invisible="status != 'failed'" readonly="1"/>
                        </group>
                    </group>
                    <group string="User Agent">
                        <field name="user_agent" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Login Log Search View -->
    <record id="user_login_log_search_view" model="ir.ui.view">
        <field name="name">user.login.log.search</field>
        <field name="model">user.login.log</field>
        <field name="arch" type="xml">
            <search string="User Login Logs">
                <field name="user_id" string="User"/>
                <field name="status" string="Status"/>
                <field name="login_time" string="Login Time"/>
                <field name="ip_address" string="IP Address"/>
                <group>
                    <filter string="By User" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="By Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="By Date" name="group_by_date" context="{'group_by': 'login_time'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Login Log Action -->
    <record id="user_login_log_action" model="ir.actions.act_window">
        <field name="name">User Login Logs</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">user.login.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="user_login_log_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No login logs found
            </p><p>
                This page displays all user login logs in the system.
            </p>
        </field>
    </record>

    <!-- Login Log Menu -->
    <menuitem id="user_login_log_submenu" name="Login Logs"
              parent="user_operation_log_menu" action="user_login_log_action" sequence="20"/>
</odoo>
