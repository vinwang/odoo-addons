<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Operation Rule List View -->
    <record id="user_operation_rule_list_view" model="ir.ui.view">
        <field name="name">user.operation.rule.list</field>
        <field name="model">user.operation.rule</field>
        <field name="arch" type="xml">
            <list string="User Operation Rules">
                <field name="name"/>
                <field name="model_description"/>
                <field name="operation_type"/>
                <field name="state"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Operation Rule Form View -->
    <record id="user_operation_rule_form_view" model="ir.ui.view">
        <field name="name">user.operation.rule.form</field>
        <field name="model">user.operation.rule</field>
        <field name="arch" type="xml">
            <form string="User Operation Rule">
                <header>
                    <button name="action_activate" type="object" string="Activate" class="oe_highlight"
                            invisible="state == 'active'"/>
                    <button name="action_deactivate" type="object" string="Deactivate"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_id"/>
                            <field name="model_name" invisible="1"/>
                            <field name="operation_type"/>
                            <field name="rule_mode" widget="radio"/>
                            <field name="log_level"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="user_ids" widget="many2many_tags"
                                   placeholder="All users..."/>
                        </group>
                    </group>
                    <group string="Excluded Fields">
                        <field name="fields_to_exclude_ids"
                               domain="[('model_id', '=', model_id)]"
                               invisible="not model_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Operation Rule Search View -->
    <record id="user_operation_rule_search_view" model="ir.ui.view">
        <field name="name">user.operation.rule.search</field>
        <field name="model">user.operation.rule</field>
        <field name="arch" type="xml">
            <search string="User Operation Rules">
                <field name="name" string="Rule Name"/>
                <field name="model_id" string="Model"/>
                <field name="operation_type" string="Operation Type"/>
                <field name="state" string="State"/>
                <field name="active" string="Active"/>
                <filter name="active_rules" string="Active Rules" domain="[('state', '=', 'active')]"/>
                <group>
                    <filter string="By Model" name="group_by_model" context="{'group_by': 'model_id'}"/>
                    <filter string="By Operation Type" name="group_by_operation" context="{'group_by': 'operation_type'}"/>
                    <filter string="By State" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Operation Rule Action -->
    <record id="user_operation_rule_action" model="ir.actions.act_window">
        <field name="name">User Operation Rules</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">user.operation.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="user_operation_rule_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No operation rules found
            </p><p>
                Configure which models and operation types need to be logged.
            </p>
        </field>
    </record>

    <!-- Operation Rule Menu -->
    <menuitem id="user_operation_rule_submenu" name="Operation Rules"
              parent="user_operation_log_menu" action="user_operation_rule_action" sequence="30"/>
</odoo>
